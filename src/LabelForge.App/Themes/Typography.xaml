         LabelForge Design System â€“ Typography
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->

    <!-- Font sizes -->
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeXS">10</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeSM">11</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeMD">12</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeLG">13</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSizeXL">15</system:Double>
    <system:Double xmlns:system="clr-namespace:System;assembly=mscorlib" x:Key="FontSize2XL">18</system:Double>

    <!-- TextBlock style presets -->
    <Style x:Key="TextBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeMD}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="TextBodySmStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="TextMutedStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="TextSecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
    </Style>

    <Style x:Key="TextLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="TextHeadingStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeLG}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="TextStatusStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeXS}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="TextMonoStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{DynamicResource FontSizeSM}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="FontFamily" Value="Cascadia Mono, Consolas, Courier New"/>
    </Style>

</ResourceDictionary>
