<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════
         LabelForge Design System – Color Tokens
         Dark IDE theme (VS Code / Figma inspired)
         ═══════════════════════════════════════════════════ -->

    <!-- Backgrounds -->
    <Color x:Key="DeepBgColor">#0D1117</Color>
    <Color x:Key="PanelBgColor">#161B22</Color>
    <Color x:Key="SurfaceBgColor">#21262D</Color>
    <Color x:Key="ElevatedBgColor">#2D333B</Color>
    <Color x:Key="InputBgColor">#0D1117</Color>
    <Color x:Key="HoverBgColor">#3D4450</Color>
    <Color x:Key="HoverBgBrightColor">#454E5C</Color>
    <Color x:Key="CanvasBgColor">#0A0E13</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#30363D</Color>
    <Color x:Key="BorderSubtleColor">#21262D</Color>
    <Color x:Key="BorderActiveColor">#58A6FF</Color>

    <!-- Text -->
    <Color x:Key="TextPrimaryColor">#E6EDF3</Color>
    <Color x:Key="TextSecondaryColor">#8B949E</Color>
    <Color x:Key="TextMutedColor">#484F58</Color>
    <Color x:Key="TextOnAccentColor">#FFFFFF</Color>

    <!-- Accent / Interactive -->
    <Color x:Key="AccentBlueColor">#58A6FF</Color>
    <Color x:Key="AccentBlueHoverColor">#79B8FF</Color>
    <Color x:Key="AccentBlueMutedColor">#1F6FEB</Color>
    <Color x:Key="AccentGreenColor">#3FB950</Color>
    <Color x:Key="AccentGreenMutedColor">#238636</Color>
    <Color x:Key="DangerRedColor">#F85149</Color>
    <Color x:Key="DangerRedHoverColor">#FF7B72</Color>
    <Color x:Key="WarningColor">#D29922</Color>

    <!-- Selection -->
    <Color x:Key="SelectionBgColor">#1F6FEB55</Color>
    <Color x:Key="SelectionBorderColor">#58A6FF</Color>
    <Color x:Key="ToolActiveBgColor">#388BFD40</Color>

    <!-- ─── Brush Resources ─── -->

    <!-- Backgrounds -->
    <SolidColorBrush x:Key="DeepBgBrush" Color="{StaticResource DeepBgColor}"/>
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBgColor}"/>
    <SolidColorBrush x:Key="SurfaceBgBrush" Color="{StaticResource SurfaceBgColor}"/>
    <SolidColorBrush x:Key="ElevatedBgBrush" Color="{StaticResource ElevatedBgColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="HoverBgBrush" Color="{StaticResource HoverBgColor}"/>
    <SolidColorBrush x:Key="HoverBgBrightBrush" Color="{StaticResource HoverBgBrightColor}"/>
    <SolidColorBrush x:Key="CanvasBgBrush" Color="{StaticResource CanvasBgColor}"/>

    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtleColor}"/>
    <SolidColorBrush x:Key="BorderActiveBrush" Color="{StaticResource BorderActiveColor}"/>

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="{StaticResource TextOnAccentColor}"/>

    <!-- Accent -->
    <SolidColorBrush x:Key="AccentBlueBrush" Color="{StaticResource AccentBlueColor}"/>
    <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="{StaticResource AccentBlueHoverColor}"/>
    <SolidColorBrush x:Key="AccentBlueMutedBrush" Color="{StaticResource AccentBlueMutedColor}"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}"/>
    <SolidColorBrush x:Key="AccentGreenMutedBrush" Color="{StaticResource AccentGreenMutedColor}"/>
    <SolidColorBrush x:Key="DangerRedBrush" Color="{StaticResource DangerRedColor}"/>
    <SolidColorBrush x:Key="DangerRedHoverBrush" Color="{StaticResource DangerRedHoverColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="SelectionBgBrush" Color="{StaticResource SelectionBgColor}"/>
    <SolidColorBrush x:Key="SelectionBorderBrush" Color="{StaticResource SelectionBorderColor}"/>
    <SolidColorBrush x:Key="ToolActiveBgBrush" Color="{StaticResource ToolActiveBgColor}"/>

    <!-- Transparent -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

</ResourceDictionary>
