<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
         LabelForge â€“ Slider Style
         â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â• -->

    <Style TargetType="Slider">
        <Setter Property="Foreground" Value="{DynamicResource AccentBlueBrush}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBgBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid>
                        <!-- Full track background – always visible, shows the "empty" portion -->
                        <Border Height="4"
                                VerticalAlignment="Center"
                                CornerRadius="2"
                                Background="{DynamicResource ElevatedBgBrush}"/>

                        <Track x:Name="PART_Track" VerticalAlignment="Center">
                            <!-- Filled (left) portion – bright accent blue -->
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{x:Null}"
                                              Background="{DynamicResource AccentBlueBrush}"
                                              BorderThickness="0"
                                              Height="4"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            </Track.DecreaseRepeatButton>
                            <!-- Unfilled (right) portion – transparent, background shows through -->
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{x:Null}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Height="4"
                                              VerticalAlignment="Center"
                                              IsHitTestVisible="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb x:Name="Thumb">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse x:Name="ThumbEllipse"
                                                     Width="13"
                                                     Height="13"
                                                     Fill="{DynamicResource AccentBlueBrush}"
                                                     Stroke="{DynamicResource DeepBgBrush}"
                                                     StrokeThickness="2"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbEllipse" Property="Fill"
                                                            Value="{DynamicResource AccentBlueHoverBrush}"/>
                                                    <Setter TargetName="ThumbEllipse" Property="Width"  Value="14"/>
                                                    <Setter TargetName="ThumbEllipse" Property="Height" Value="14"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbEllipse" Property="Fill"
                                                            Value="{DynamicResource AccentBlueHoverBrush}"/>
                                                    <Setter TargetName="ThumbEllipse" Property="Width"  Value="15"/>
                                                    <Setter TargetName="ThumbEllipse" Property="Height" Value="15"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
