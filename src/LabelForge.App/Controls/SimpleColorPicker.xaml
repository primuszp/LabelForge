<UserControl x:Class="LabelForge.App.Controls.SimpleColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="26">
    <Grid>
        <Button x:Name="DropDownButton"
                Click="DropDownButtonOnClick"
                Padding="5,3"
                HorizontalContentAlignment="Stretch">
            <DockPanel LastChildFill="True">
                <Border x:Name="Swatch"
                        Width="18"
                        Height="14"
                        Margin="0,0,6,0"
                        CornerRadius="3"
                        DockPanel.Dock="Left"/>
                <TextBlock x:Name="ColorText"
                           VerticalAlignment="Center"
                           FontSize="11"/>
            </DockPanel>
        </Button>

        <Popup x:Name="PalettePopup"
               PlacementTarget="{Binding ElementName=DropDownButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ElevatedBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="8">
                <StackPanel Width="200">
                    <UniformGrid x:Name="PaletteGrid"
                                 Columns="8"
                                 Margin="0,0,0,8"/>
                    <TextBox x:Name="HexTextBox"
                             TextChanged="HexTextBoxOnTextChanged"
                             Padding="6,4"
                             FontSize="11"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
