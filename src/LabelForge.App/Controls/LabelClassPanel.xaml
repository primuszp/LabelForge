<UserControl x:Class="LabelForge.App.Controls.LabelClassPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:LabelForge.App.Models"
             xmlns:converters="clr-namespace:LabelForge.App.Converters"
             xmlns:controls="clr-namespace:LabelForge.App.Controls"
             Background="{StaticResource PanelBgBrush}">
    <UserControl.Resources>
        <converters:HexToBrushConverter x:Key="HexBrush"/>
        <converters:CountBadgeConverter x:Key="CountBadge"/>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource Panel.Labels}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        x:Name="AddLabelButton"
                        Style="{StaticResource IconButtonStyle}"
                        Width="22" Height="22"
                        ToolTip="{DynamicResource Tip.AddLabel}"
                        Click="AddLabelOnClick">
                    <Path Data="M8,2 V14 M2,8 H14"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="2"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stretch="Uniform"
                          Width="12" Height="12"
                          Fill="Transparent"/>
                </Button>
            </Grid>
        </Border>

        <!-- Add label row (inline) -->
        <Border x:Name="AddLabelRow"
                DockPanel.Dock="Top"
                Visibility="Collapsed"
                Background="{StaticResource SurfaceBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewLabelTextBox"
                         Padding="5,4"
                         FontSize="12"
                         KeyDown="NewLabelTextBoxOnKeyDown"/>
                <Button Grid.Column="1"
                        Content="{DynamicResource Action.Add}"
                        Style="{StaticResource AccentButtonStyle}"
                        Margin="4,0,0,0"
                        Padding="8,4"
                        FontSize="11"
                        Click="ConfirmAddLabelOnClick"/>
                <Button Grid.Column="2"
                        Content="✕"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="2,0,0,0"
                        Padding="6,4"
                        FontSize="11"
                        Click="CancelAddLabelOnClick"/>
            </Grid>
        </Border>

        <!-- Label list -->
        <ListBox x:Name="LabelList"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectionChanged="LabelListOnSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:LabelClass}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                        <Setter Property="Opacity" Value="0.45"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <!-- HotKey badge -->
                        <Border Width="16" Height="16"
                                Background="{StaticResource SurfaceBgBrush}"
                                CornerRadius="3"
                                Margin="0,0,6,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding HotKey}"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Color picker compact swatch -->
                        <controls:SimpleColorPicker Grid.Column="1"
                                                     SelectedColorHex="{Binding ColorHex, Mode=TwoWay}"
                                                     ShowLabel="False"
                                                     Width="30"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center"
                                                     SelectedColorHexChanged="LabelColorChangedOnClick"/>

                        <!-- Label name -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Name}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Count badge -->
                        <Border Grid.Column="3"
                                Background="{StaticResource SurfaceBgBrush}"
                                CornerRadius="8"
                                Padding="5,1"
                                Margin="4,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding AnnotationCount, Converter={StaticResource CountBadge}}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </Border>

                        <!-- Visibility toggle -->
                        <Button Grid.Column="4"
                                Style="{StaticResource IconButtonStyle}"
                                Width="20" Height="20"
                                ToolTip="Kategória láthatóság be/ki"
                                Tag="{Binding}"
                                Click="ToggleCategoryVisibilityOnClick">
                            <Path Width="12" Height="9"
                                  Fill="Transparent"
                                  StrokeThickness="1.3"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Stroke" Value="{StaticResource TextMutedBrush}"/>
                                        <!-- Eye open -->
                                        <Setter Property="Data"
                                                Value="M1,8 C3,4 13,4 15,8 C13,12 3,12 1,8 Z M8,5.5 A2.5,2.5 0 1,0 8,10.5 A2.5,2.5 0 1,0 8,5.5 Z"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVisible}" Value="True">
                                                <Setter Property="Stroke" Value="{StaticResource AccentBlueBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                <!-- Eye with slash -->
                                                <Setter Property="Data"
                                                        Value="M1,8 C3,4 13,4 15,8 C13,12 3,12 1,8 Z M8,5.5 A2.5,2.5 0 1,0 8,10.5 A2.5,2.5 0 1,0 8,5.5 Z M2.5,2.5 L13.5,13.5"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>

                        <!-- Visual settings button: sliders/tune icon -->
                        <Button Grid.Column="5"
                                Style="{StaticResource IconButtonStyle}"
                                Width="20" Height="20"
                                ToolTip="Vizuális beállítások (kitöltés átlátszóság, border vastagság)"
                                Tag="{Binding}"
                                Click="OpenVisualSettingsOnClick">
                            <!-- Sliders icon: 2 horizontal lines with circle thumbs -->
                            <Path Data="M1,5 H5.5 M5.5,3 V7 M5.5,5 H15 M1,11 H10 M10,9 V13 M10,11 H15"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.3"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="12" Height="11"/>
                        </Button>

                        <!-- Delete button -->
                        <Button Grid.Column="6"
                                Style="{StaticResource IconButtonStyle}"
                                Width="20" Height="20"
                                ToolTip="{DynamicResource Tip.RemoveLabel}"
                                Tag="{Binding}"
                                Click="RemoveLabelOnClick">
                            <Path Data="M3,3 L13,13 M13,3 L3,13"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Width="8" Height="8"
                                  Fill="Transparent"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
