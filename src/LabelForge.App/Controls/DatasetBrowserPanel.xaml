<UserControl x:Class="LabelForge.App.Controls.DatasetBrowserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LabelForge.App.ViewModels"
             xmlns:converters="clr-namespace:LabelForge.App.Converters"
             Background="{StaticResource PanelBgBrush}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource Panel.Dataset}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        x:Name="OpenFolderButton"
                        Style="{StaticResource IconButtonStyle}"
                        Width="22" Height="22"
                        ToolTip="{DynamicResource Tip.OpenFolder}"
                        Click="OpenFolderOnClick">
                    <Path Data="M2,4 H6 L8,6 H14 V13 H2 Z"
                          Fill="{StaticResource TextSecondaryBrush}"
                          Stretch="Uniform" Width="14" Height="14"/>
                </Button>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel>
                <TextBox x:Name="SearchBox" Height="26" Padding="6,3" FontSize="11"
                         ToolTip="Kereses fajlnev alapjan" TextChanged="FilterOnChanged"/>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox x:Name="MonthFilter" Height="24" FontSize="10" SelectionChanged="FilterOnChanged"/>
                    <ComboBox x:Name="StatusFilter" Grid.Column="1" Height="24" Margin="4,0,0,0" FontSize="10"
                              SelectionChanged="FilterOnChanged">
                        <ComboBoxItem Content="Minden statusz" Tag="" IsSelected="True"/>
                        <ComboBoxItem Content="Fuggoben" Tag="Pending"/>
                        <ComboBoxItem Content="AI javaslat" Tag="AiGenerated"/>
                        <ComboBoxItem Content="Ellenorzott" Tag="Reviewed"/>
                        <ComboBoxItem Content="Jovahagyott" Tag="Approved"/>
                        <ComboBoxItem Content="Elutasitott" Tag="Rejected"/>
                    </ComboBox>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Navigation bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource SurfaceBgBrush}"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton"
                        Style="{StaticResource IconButtonStyle}"
                        Width="26" Height="26"
                        ToolTip="{DynamicResource Tip.PreviousImage}"
                        Click="PrevOnClick">
                    <Path Data="M10,2 L4,8 L10,14"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stretch="Uniform"
                          Width="10" Height="10"
                          Fill="Transparent"/>
                </Button>

                <TextBlock Grid.Column="1"
                           x:Name="PositionText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="—"/>

                <Button Grid.Column="2" x:Name="LoadMoreButton" Content="+500" Margin="3,0"
                        Height="26" Padding="6,0" ToolTip="Tovabbi kepek betoltese" Click="LoadMoreOnClick"/>

                <Button Grid.Column="3"
                        x:Name="NextButton"
                        Style="{StaticResource IconButtonStyle}"
                        Width="26" Height="26"
                        ToolTip="{DynamicResource Tip.NextImage}"
                        Click="NextOnClick">
                    <Path Data="M6,2 L12,8 L6,14"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stretch="Uniform"
                          Width="10" Height="10"
                          Fill="Transparent"/>
                </Button>
            </Grid>
        </Border>

        <!-- Empty state -->
        <Grid x:Name="EmptyStatePanel"
              Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
                <Path Data="M2,4 H6 L8,6 H14 V13 H2 Z"
                      Fill="{StaticResource TextMutedBrush}"
                      Stretch="Uniform"
                      Width="32" Height="32"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
                <TextBlock Text="{DynamicResource Empty.OpenFolder}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Image list -->
        <ListBox x:Name="ImageList"
                 Visibility="Collapsed"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectionChanged="ImageListOnSelectionChanged"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 VirtualizingPanel.CacheLength="1,1"
                 VirtualizingPanel.CacheLengthUnit="Page"
                 ScrollViewer.CanContentScroll="True">
            <ListBox.GroupStyle>
                <GroupStyle>
                    <GroupStyle.ContainerStyle>
                        <Style TargetType="{x:Type GroupItem}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                        <Expander x:Name="GroupExpander" IsExpanded="False" Margin="0,1,0,2">
                                            <Expander.Template>
                                                <ControlTemplate TargetType="{x:Type Expander}">
                                                    <DockPanel>
                                                        <ToggleButton DockPanel.Dock="Top"
                                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                      Content="{TemplateBinding Header}"
                                                                      Background="Transparent" BorderThickness="0"
                                                                      HorizontalContentAlignment="Stretch">
                                                            <ToggleButton.Template>
                                                                <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                                    <Border x:Name="HeaderBackground" Background="Transparent"
                                                                            Padding="2" CornerRadius="3">
                                                                        <ContentPresenter HorizontalAlignment="Stretch"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="HeaderBackground" Property="Background"
                                                                                    Value="{StaticResource SurfaceBgBrush}"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </ToggleButton.Template>
                                                        </ToggleButton>
                                                        <ContentPresenter x:Name="ExpandedContent" Visibility="Collapsed"
                                                                          ContentSource="Content"/>
                                                    </DockPanel>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsExpanded" Value="True">
                                                            <Setter TargetName="ExpandedContent" Property="Visibility" Value="Visible"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Expander.Template>
                                            <Expander.Header>
                                                <Grid Margin="0,3,4,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="22"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="18" Height="18" CornerRadius="3"
                                                            Background="{StaticResource SurfaceBgBrush}">
                                                        <Path Data="M5,3 L10,8 L5,13" Stroke="{StaticResource TextSecondaryBrush}"
                                                              StrokeThickness="1.5" StrokeStartLineCap="Round"
                                                              StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                                              Width="8" Height="10" Stretch="Uniform">
                                                            <Path.Style>
                                                                <Style TargetType="Path">
                                                                    <Setter Property="RenderTransform">
                                                                        <Setter.Value><RotateTransform Angle="0" CenterX="4" CenterY="5"/></Setter.Value>
                                                                    </Setter>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsExpanded, ElementName=GroupExpander}" Value="True">
                                                                            <Setter Property="RenderTransform">
                                                                                <Setter.Value><RotateTransform Angle="90" CenterX="4" CenterY="5"/></Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Path.Style>
                                                        </Path>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Border Grid.Column="2" Background="{StaticResource SurfaceBgBrush}"
                                                            CornerRadius="3" Padding="4,1" Margin="6,0,0,0">
                                                        <TextBlock Text="{Binding ItemCount}" FontSize="9"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </Border>
                                                </Grid>
                                            </Expander.Header>
                                            <ItemsPresenter Margin="12,0,0,0"/>
                                        </Expander>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </GroupStyle.ContainerStyle>
                </GroupStyle>
            </ListBox.GroupStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:DatasetImageEntry}">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding FileName}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding FilePath}"/>

                        <!-- Annotation indicator badge -->
                        <Border Grid.Column="1"
                                Background="{StaticResource AccentGreenMutedBrush}"
                                BorderBrush="{StaticResource AccentGreenBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="3,0"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAnnotations, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="✓"
                                       FontSize="8"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Grid.Column="2" Text="{Binding WorkflowStatus}" FontSize="8"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
