<UserControl x:Class="LabelForge.App.Controls.DatasetBrowserPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LabelForge.App.ViewModels"
             xmlns:converters="clr-namespace:LabelForge.App.Converters"
             Background="{StaticResource PanelBgBrush}">
    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{DynamicResource Panel.Dataset}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        x:Name="OpenFolderButton"
                        Style="{StaticResource IconButtonStyle}"
                        Width="22" Height="22"
                        ToolTip="{DynamicResource Tip.OpenFolder}"
                        Click="OpenFolderOnClick">
                    <Path Data="M2,4 H6 L8,6 H14 V13 H2 Z"
                          Fill="{StaticResource TextSecondaryBrush}"
                          Stretch="Uniform" Width="14" Height="14"/>
                </Button>
            </Grid>
        </Border>

        <!-- Navigation bar -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource SurfaceBgBrush}"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="PrevButton"
                        Style="{StaticResource IconButtonStyle}"
                        Width="26" Height="26"
                        ToolTip="{DynamicResource Tip.PreviousImage}"
                        Click="PrevOnClick">
                    <Path Data="M10,2 L4,8 L10,14"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stretch="Uniform"
                          Width="10" Height="10"
                          Fill="Transparent"/>
                </Button>

                <TextBlock Grid.Column="1"
                           x:Name="PositionText"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Text="—"/>

                <Button Grid.Column="2"
                        x:Name="NextButton"
                        Style="{StaticResource IconButtonStyle}"
                        Width="26" Height="26"
                        ToolTip="{DynamicResource Tip.NextImage}"
                        Click="NextOnClick">
                    <Path Data="M6,2 L12,8 L6,14"
                          Stroke="{StaticResource TextSecondaryBrush}"
                          StrokeThickness="1.5"
                          StrokeLineJoin="Round"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Stretch="Uniform"
                          Width="10" Height="10"
                          Fill="Transparent"/>
                </Button>
            </Grid>
        </Border>

        <!-- Empty state -->
        <Grid x:Name="EmptyStatePanel"
              Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16">
                <Path Data="M2,4 H6 L8,6 H14 V13 H2 Z"
                      Fill="{StaticResource TextMutedBrush}"
                      Stretch="Uniform"
                      Width="32" Height="32"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>
                <TextBlock Text="{DynamicResource Empty.OpenFolder}"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Image list -->
        <ListBox x:Name="ImageList"
                 Visibility="Collapsed"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectionChanged="ImageListOnSelectionChanged"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:DatasetImageEntry}">
                    <Grid Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="{Binding FileName}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   ToolTip="{Binding FilePath}"/>

                        <!-- Annotation indicator badge -->
                        <Border Grid.Column="1"
                                Background="{StaticResource AccentGreenMutedBrush}"
                                BorderBrush="{StaticResource AccentGreenBrush}"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="3,0"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Visibility="{Binding HasAnnotations, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="✓"
                                       FontSize="8"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
