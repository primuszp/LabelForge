<UserControl x:Class="LabelForge.App.Controls.AnnotationInspectorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:LabelForge.Core;assembly=LabelForge.Core"
             xmlns:converters="clr-namespace:LabelForge.App.Converters"
             xmlns:controls="clr-namespace:LabelForge.App.Controls"
             Background="{StaticResource PanelBgBrush}">
    <UserControl.Resources>
        <converters:ShapeKindToIconConverter x:Key="ShapeIcon"/>
        <converters:VisibilityToIconConverter x:Key="VisIcon"/>
        <converters:HexToBrushConverter x:Key="HexBrush"/>
        <converters:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="ANNOTATIONS"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Count -->
                    <TextBlock x:Name="CountLabel"
                               FontSize="10"
                               Foreground="{StaticResource TextMutedBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>

                    <!-- Delete selected -->
                    <Button x:Name="DeleteSelectedButton"
                            Style="{StaticResource IconButtonStyle}"
                            Width="22" Height="22"
                            ToolTip="Kijelöltek törlése (Del)"
                            Click="DeleteSelectedOnClick">
                        <!-- Trash icon -->
                        <Path Data="M3,6 H13 M5,6 V12 H11 V6 M7,6 V10 M9,6 V10 M5,4 L5,3 H11 L11,4"
                              Stroke="{StaticResource TextMutedBrush}"
                              StrokeThickness="1.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Fill="Transparent"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Annotations list + detail panel -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

        <ListBox x:Name="AnnotationList"
                 Grid.Row="0"
                 BorderThickness="0"
                 Background="Transparent"
                 SelectionChanged="AnnotationListOnSelectionChanged"
                 SelectionMode="Extended">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type core:Annotation}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>

                        <!-- Shape icon -->
                        <Path Width="12" Height="12"
                              Margin="0,0,6,0"
                              VerticalAlignment="Center"
                              Data="{Binding Shape.Kind, Converter={StaticResource ShapeIcon}}"
                              Fill="Transparent"
                              Stroke="{Binding Color, Converter={StaticResource HexBrush}}"
                              StrokeThickness="1.5"
                              Stretch="Uniform"/>

                        <!-- Color picker compact swatch -->
                        <controls:SimpleColorPicker Grid.Column="1"
                                                     SelectedColorHex="{Binding Color, Mode=TwoWay}"
                                                     ShowLabel="False"
                                                     Width="26"
                                                     Margin="0,0,6,0"
                                                     VerticalAlignment="Center"
                                                     SelectedColorHexChanged="AnnotationColorChangedOnClick"/>

                        <!-- Label text -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Label}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Visibility toggle -->
                        <Button Grid.Column="3"
                                Style="{StaticResource IconButtonStyle}"
                                Width="20" Height="20"
                                ToolTip="Toggle visibility"
                                Tag="{Binding}"
                                Click="ToggleVisibilityOnClick">
                            <Path Width="11" Height="11"
                                  Fill="Transparent"
                                  StrokeThickness="1.2"
                                  Data="{Binding IsVisible, Converter={StaticResource VisIcon}}"
                                  Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Stroke" Value="{StaticResource TextMutedBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsVisible}" Value="True">
                                                <Setter Property="Stroke" Value="{StaticResource AccentBlueBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                        </Button>

                        <!-- Delete -->
                        <Button Grid.Column="4"
                                Style="{StaticResource IconButtonStyle}"
                                Width="20" Height="20"
                                ToolTip="Delete annotation"
                                Tag="{Binding}"
                                Click="DeleteAnnotationOnClick">
                            <Path Data="M3,3 L13,13 M13,3 L3,13"
                                  Stroke="{StaticResource TextMutedBrush}"
                                  StrokeThickness="1.5"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="Uniform"
                                  Width="8" Height="8"
                                  Fill="Transparent"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Annotation detail panel (visible when exactly one is selected) -->
        <Border x:Name="DetailPanel"
                Grid.Row="1"
                Visibility="Collapsed"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Background="{StaticResource SurfaceBgBrush}">
            <ScrollViewer MaxHeight="260"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="DetailContent" Margin="10,8,10,10">

                    <!-- Standard flags -->
                    <TextBlock Text="FLAGEK"
                               FontSize="9" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <CheckBox x:Name="OccludedCheck"
                                  Content="Takart"
                                  FontSize="11"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,12,0"
                                  Click="FlagCheckOnClick"/>
                        <CheckBox x:Name="TruncatedCheck"
                                  Content="Vágott"
                                  FontSize="11"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Margin="0,0,12,0"
                                  Click="FlagCheckOnClick"/>
                        <CheckBox x:Name="CrowdCheck"
                                  Content="Csoport"
                                  FontSize="11"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  Click="FlagCheckOnClick"/>
                    </StackPanel>

                    <!-- Confidence -->
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bizonyosság"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                        <Slider x:Name="ConfidenceSlider"
                                Grid.Column="1"
                                Minimum="0" Maximum="1"
                                TickFrequency="0.05"
                                Width="90"
                                VerticalAlignment="Center"
                                Margin="8,0,6,0"
                                ValueChanged="ConfidenceSliderOnValueChanged"/>
                        <TextBlock x:Name="ConfidenceLabel"
                                   Grid.Column="2"
                                   FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center"
                                   MinWidth="32"
                                   Text="–"/>
                    </Grid>

                    <!-- Custom attributes section -->
                    <Border Margin="0,10,0,4"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="0,6,0,0">
                        <TextBlock Text="EGYÉNI ATTRIBÚTUMOK"
                                   FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </Border>

                    <!-- Add attribute row -->
                    <Grid Margin="0,2,0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AttrKeyBox"
                                 Grid.Column="0"
                                 Padding="4,3"
                                 FontSize="11"
                                 ToolTip="Kulcs"
                                 KeyDown="AttrBoxOnKeyDown"/>
                        <TextBox x:Name="AttrValueBox"
                                 Grid.Column="2"
                                 Padding="4,3"
                                 FontSize="11"
                                 ToolTip="Érték"
                                 KeyDown="AttrBoxOnKeyDown"/>
                        <Button Grid.Column="4"
                                Style="{StaticResource AccentButtonStyle}"
                                Padding="7,3"
                                FontSize="12"
                                Content="+"
                                Click="AddAttrOnClick"/>
                    </Grid>

                    <!-- Attribute list -->
                    <StackPanel x:Name="AttrListPanel" Margin="0,2,0,0"/>

                </StackPanel>
            </ScrollViewer>
        </Border>

        </Grid>
    </DockPanel>
</UserControl>
