<UserControl x:Class="LabelForge.App.Controls.AppStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="26"
             Background="{StaticResource PanelBgBrush}">
    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
        <Grid Margin="10,0">
            <Grid.ColumnDefinitions>
                <!-- Tool -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <!-- Spacer -->
                <ColumnDefinition Width="*"/>
                <!-- Cursor -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <!-- Zoom -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <!-- Count -->
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Tool icon (cursor) -->
            <Path Grid.Column="0"
                  Data="M4,2 L4,13 L6.5,10.5 L8,14 L9.5,13.5 L8,10 L11,10 Z"
                  Fill="{StaticResource TextMutedBrush}"
                  Stretch="Uniform" Width="10" Height="10"
                  VerticalAlignment="Center"/>
            <!-- Tool text -->
            <TextBlock x:Name="ToolText"
                       Grid.Column="1"
                       Style="{StaticResource TextStatusStyle}"
                       Margin="4,0,0,0"/>

            <!-- Spacer -->
            <TextBlock Grid.Column="3"/>

            <!-- Crosshair icon for cursor position -->
            <Path Grid.Column="4"
                  Data="M8,1 V5 M8,11 V15 M1,8 H5 M11,8 H15 M8,6 A2,2 0 1,0 8,10 A2,2 0 1,0 8,6 Z"
                  Stroke="{StaticResource TextMutedBrush}"
                  StrokeThickness="1.2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Stretch="Uniform" Width="10" Height="10"
                  VerticalAlignment="Center"/>
            <!-- Cursor text -->
            <TextBlock x:Name="CursorText"
                       Grid.Column="5"
                       Style="{StaticResource TextStatusStyle}"
                       Margin="4,0,0,0"/>

            <!-- Zoom icon (magnifier) -->
            <Path Grid.Column="7"
                  Data="M6,2 A4,4 0 1,0 6,10 A4,4 0 1,0 6,2 Z M9,9 L14,14"
                  Stroke="{StaticResource TextMutedBrush}"
                  StrokeThickness="1.3"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Fill="Transparent"
                  Stretch="Uniform" Width="10" Height="10"
                  VerticalAlignment="Center"/>
            <!-- Zoom text -->
            <TextBlock x:Name="ZoomText"
                       Grid.Column="8"
                       Style="{StaticResource TextStatusStyle}"
                       Margin="4,0,0,0"/>

            <!-- Tag/count icon -->
            <Path Grid.Column="10"
                  Data="M2,2 H9 L14,8 L9,14 H2 V2 Z M5,8 A1,1 0 1,0 5,8.001 Z"
                  Stroke="{StaticResource TextMutedBrush}"
                  StrokeThickness="1.2"
                  StrokeLineJoin="Round"
                  Fill="Transparent"
                  Stretch="Uniform" Width="10" Height="10"
                  VerticalAlignment="Center"/>
            <!-- Annotation count -->
            <TextBlock x:Name="CountText"
                       Grid.Column="11"
                       Style="{StaticResource TextStatusStyle}"
                       Margin="4,0,0,0"/>
        </Grid>
    </Border>
</UserControl>
