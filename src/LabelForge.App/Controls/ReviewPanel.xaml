<UserControl x:Class="LabelForge.App.Controls.ReviewPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource PanelBgBrush}">
    <StackPanel Margin="10">
        <TextBlock Text="Munkafolyamat" FontWeight="SemiBold" FontSize="11" Margin="0,0,0,6"/>
        <ComboBox x:Name="StatusBox" SelectionChanged="ValueOnChanged"/>
        <TextBlock Text="Adathalmaz split" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,6"/>
        <ComboBox x:Name="SplitBox" SelectionChanged="ValueOnChanged"/>
        <TextBlock Text="Kepminoseg" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,6"/>
        <ComboBox x:Name="QualityBox" SelectionChanged="ValueOnChanged"/>
        <TextBlock Text="Ellenorzo" FontWeight="SemiBold" FontSize="11" Margin="0,12,0,6"/>
        <TextBox x:Name="ReviewerBox" TextChanged="ValueOnChanged"/>
        <TextBlock Margin="0,14,0,0" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"
                   Text="Alt+1 Fuggoben   Alt+2 Ellenorzott   Alt+3 Jovahagyott   Alt+4 Elutasitott"
                   TextWrapping="Wrap"/>
    </StackPanel>
</UserControl>
