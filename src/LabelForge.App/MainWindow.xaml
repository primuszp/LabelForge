<Window x:Class="LabelForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LabelForge.App.Controls"
        xmlns:imageControl="clr-namespace:LabelForge.ImageControl;assembly=LabelForge.ImageControl"
        xmlns:tools="clr-namespace:LabelForge.Tools;assembly=LabelForge.Tools"
        Title="LabelForge" Height="860" Width="1360" MinHeight="600" MinWidth="960"
        Background="{StaticResource DeepBgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI"
        Closing="WindowOnClosing">

    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenImageCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding RedoCommand}"/>
        <KeyBinding Key="A" Modifiers="Control" Command="{Binding SelectAllCommand}"/>
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding CopyAnnotationsCommand}"/>
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding PasteAnnotationsCommand}"/>
        <KeyBinding Key="Delete" Command="{Binding DeleteSelectedCommand}"/>
        <KeyBinding Key="D1" Modifiers="Alt" Command="{Binding PendingStatusCommand}"/>
        <KeyBinding Key="D2" Modifiers="Alt" Command="{Binding ReviewedStatusCommand}"/>
        <KeyBinding Key="D3" Modifiers="Alt" Command="{Binding ApprovedStatusCommand}"/>
        <KeyBinding Key="D4" Modifiers="Alt" Command="{Binding RejectedStatusCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- ══════ MENU BAR ══════ -->
        <Menu DockPanel.Dock="Top"
              Background="{StaticResource PanelBgBrush}"
              Foreground="{StaticResource TextPrimaryBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="0,0,0,1"
              Padding="4,2"
              FontSize="12">
            <MenuItem Header="{DynamicResource Menu.File}" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem Header="Új projekt…" Click="NewProjectOnClick"/>
                <MenuItem Header="Projekt megnyitása…" Click="OpenProjectOnClick"/>
                <MenuItem x:Name="SaveProjectMenuItem"
                          Header="Projekt mentése"
                          InputGestureText="Ctrl+Shift+P"
                          IsEnabled="False"
                          Click="SaveProjectOnClick"/>
                <MenuItem x:Name="SaveProjectAsMenuItem"
                          Header="Projekt mentése másként…"
                          IsEnabled="False"
                          Click="SaveProjectAsOnClick"/>
                <MenuItem x:Name="CloseProjectMenuItem"
                          Header="Projekt bezárása"
                          IsEnabled="False"
                          Click="CloseProjectOnClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Action.OpenImage}" InputGestureText="Ctrl+O" Click="OpenImageOnClick"/>
                <MenuItem Header="{DynamicResource Action.OpenFolder}" InputGestureText="Ctrl+Shift+O" Click="OpenFolderOnClick"/>
                <MenuItem Header="Dataset megnyitása..." Click="OpenDatasetOnClick"/>
                <MenuItem Header="Import..." Click="ImportOnClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Action.Save}" InputGestureText="Ctrl+S" Click="SaveOnClick"/>
                <MenuItem Header="{DynamicResource Action.SaveAs}" InputGestureText="Ctrl+Shift+S" Click="SaveAsOnClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Action.Exit}" Click="ExitOnClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Edit}" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem Header="{DynamicResource Action.Undo}" InputGestureText="Ctrl+Z" Click="UndoOnClick"/>
                <MenuItem Header="{DynamicResource Action.Redo}" InputGestureText="Ctrl+Y" Click="RedoOnClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Action.SelectAll}" InputGestureText="Ctrl+A" Click="SelectAllOnClick"/>
                <MenuItem Header="Annotaciok masolasa" InputGestureText="Ctrl+C" Click="CopyAnnotationsOnClick"/>
                <MenuItem Header="Annotaciok beillesztese" InputGestureText="Ctrl+V" Click="PasteAnnotationsOnClick"/>
                <MenuItem Header="{DynamicResource Action.DeleteSelected}" InputGestureText="Del" Click="DeleteSelectedOnClick"/>
                <MenuItem Header="{DynamicResource Action.DeleteAll}" Click="DeleteAllOnClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.View}" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem Header="{DynamicResource Action.Fit}" InputGestureText="F" Click="FitOnClick"/>
                <MenuItem Header="{DynamicResource Action.Zoom100}" InputGestureText="0" Click="ResetZoomOnClick"/>
                <Separator/>
                <MenuItem Header="{DynamicResource Action.ToggleDataset}" Click="ToggleDatasetPanelOnClick"/>
                <MenuItem Header="{DynamicResource Action.ToggleInspector}" Click="ToggleInspectorOnClick"/>
                <MenuItem Header="Minimap be/ki" Click="ToggleMiniMapOnClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Tools}" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem Header="{DynamicResource Tool.Select}" InputGestureText="V" Click="ToolSelectOnClick"/>
                <MenuItem Header="{DynamicResource Tool.Rectangle}" InputGestureText="R" Click="ToolRectangleOnClick"/>
                <MenuItem Header="{DynamicResource Tool.Ellipse}" InputGestureText="E" Click="ToolEllipseOnClick"/>
                <MenuItem Header="{DynamicResource Tool.Polygon}" InputGestureText="P" Click="ToolPolygonOnClick"/>
                <MenuItem Header="{DynamicResource Tool.FreehandPolygon}" InputGestureText="B" Click="ToolFreehandOnClick"/>
                <MenuItem Header="{DynamicResource Tool.Polyline}" InputGestureText="L" Click="ToolPolylineOnClick"/>
                <MenuItem Header="{DynamicResource Tool.Point}" InputGestureText="O" Click="ToolPointOnClick"/>
                <MenuItem Header="AI modellek es SAM3 beallitasok..." Click="AutoLabelOnClick"/>
                <MenuItem Header="AI cimke-megfeleltetes..." Click="LabelMappingOnClick"/>
                <MenuItem Header="Javaslatok elfogadása mind" Click="AcceptAllSuggestionsOnClick"/>
                <MenuItem Header="Javaslatok törlése" Click="RejectAllSuggestionsOnClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Export}" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem Header="{DynamicResource Action.ExportAnnotations}" Click="ExportOnClick"/>
            </MenuItem>
            <MenuItem Header="{DynamicResource Menu.Language}" Foreground="{StaticResource TextPrimaryBrush}">
                <MenuItem x:Name="LanguageAutoMenuItem" Header="{DynamicResource Language.Auto}" Tag="auto" Click="LanguageOnClick"/>
                <MenuItem x:Name="LanguageEnglishMenuItem" Header="{DynamicResource Language.English}" Tag="en" Click="LanguageOnClick"/>
                <MenuItem x:Name="LanguageHungarianMenuItem" Header="{DynamicResource Language.Hungarian}" Tag="hu" Click="LanguageOnClick"/>
            </MenuItem>
        </Menu>

        <!-- ══════ TOOLBAR ══════ -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource PanelBgBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <StackPanel Orientation="Horizontal">

                <!-- File actions -->
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        ToolTip="{DynamicResource Action.OpenImage}" Click="OpenImageOnClick">
                    <Path Data="M4,2 H10 L14,6 V15 H2 V2 Z M10,2 V6 H14"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.3" Stretch="Uniform" Width="14" Height="14"
                          StrokeLineJoin="Round"/>
                </Button>
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        ToolTip="{DynamicResource Action.Save}" Click="SaveOnClick">
                    <Path Data="M3,1 H11 L15,5 V15 H1 V1 Z M5,15 V9 H11 V15 M9,1 V5 H5"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.3" Stretch="Uniform" Width="14" Height="14"
                          StrokeLineJoin="Round"/>
                </Button>

                <!-- Vertical separator -->
                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>

                <!-- Tool buttons -->
                <RadioButton x:Name="SelectToolBtn" Style="{StaticResource ToolButtonStyle}"
                             GroupName="Tools" IsChecked="True"
                             ToolTip="{DynamicResource Tool.Select}" Checked="SelectToolOnChecked">
                    <Path Data="M4,2 L4,14 L7,11 L9,15 L11,14 L9,10 L13,10 Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          Stretch="Uniform" Width="14" Height="14"/>
                </RadioButton>

                <RadioButton x:Name="RectToolBtn" Style="{StaticResource ToolButtonStyle}"
                             GroupName="Tools"
                             ToolTip="{DynamicResource Tool.Rectangle}" Checked="RectangleToolOnChecked">
                    <Path Data="M1,3 H15 V13 H1 Z"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14"/>
                </RadioButton>

                <RadioButton x:Name="EllipseToolBtn" Style="{StaticResource ToolButtonStyle}"
                             GroupName="Tools"
                             ToolTip="{DynamicResource Tool.Ellipse}" Checked="EllipseToolOnChecked">
                    <Path Data="M8,2 A6,5 0 1,0 8.001,2 Z"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14"/>
                </RadioButton>

                <RadioButton x:Name="PolygonToolBtn" Style="{StaticResource ToolButtonStyle}"
                             GroupName="Tools"
                             ToolTip="{DynamicResource Tool.Polygon}" Checked="PolygonToolOnChecked">
                    <Path Data="M8,1 L14,5 L12,13 L4,13 L2,5 Z"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14"/>
                </RadioButton>

                <RadioButton x:Name="FreehandToolBtn" Style="{StaticResource ToolButtonStyle}"
                             GroupName="Tools" ToolTip="{DynamicResource Tool.FreehandPolygon}" Checked="FreehandToolOnChecked">
                    <Path Data="M2,12 C4,2 7,14 10,5 C11,2 13,3 14,2"
                          Fill="Transparent" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          StrokeThickness="1.5" Stretch="Uniform" Width="14" Height="14"/>
                </RadioButton>

                <RadioButton x:Name="PolylineToolBtn" Style="{StaticResource ToolButtonStyle}"
                             GroupName="Tools"
                             ToolTip="{DynamicResource Tool.Polyline}" Checked="PolylineToolOnChecked">
                    <Path Data="M2,12 L5,6 L9,10 L13,4"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Stretch="Uniform" Width="14" Height="14"/>
                </RadioButton>

                <RadioButton x:Name="PointToolBtn" Style="{StaticResource ToolButtonStyle}"
                             GroupName="Tools"
                             ToolTip="{DynamicResource Tool.Point}" Checked="PointToolOnChecked">
                    <Ellipse Width="7" Height="7"
                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                </RadioButton>

                <!-- Vertical separator -->
                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>

                <!-- View actions -->
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        ToolTip="{DynamicResource Action.Fit}" Click="FitOnClick">
                    <Path Data="M1,5 V1 H5 M11,1 H15 V5 M15,11 V15 H11 M5,15 H1 V11"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Stretch="Uniform" Width="14" Height="14"/>
                </Button>
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        ToolTip="100% Zoom (0)" Click="ResetZoomOnClick">
                    <TextBlock Text="1:1" FontSize="10" FontWeight="SemiBold"
                               Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                               VerticalAlignment="Center"/>
                </Button>

                <!-- Vertical separator -->
                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>

                <!-- Undo / Redo -->
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        ToolTip="Visszavonás (Ctrl+Z)" Click="UndoOnClick">
                    <!-- Undo: görbe nyíl balra -->
                    <Path Data="M5,4 L2,7 L5,10 M2,7 C2,4 6,2 10,3 C13,4 14,7 13,10"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Stretch="Uniform" Width="14" Height="12"/>
                </Button>
                <Button Style="{StaticResource IconButtonStyle}" Width="30" Height="30"
                        ToolTip="Újra (Ctrl+Y)" Click="RedoOnClick">
                    <!-- Redo: görbe nyíl jobbra -->
                    <Path Data="M11,4 L14,7 L11,10 M14,7 C14,4 10,2 6,3 C3,4 2,7 3,10"
                          Fill="Transparent"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="1.5"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                          Stretch="Uniform" Width="14" Height="12"/>
                </Button>

                <!-- Vertical separator -->
                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>

                <!-- Vertex spacing: nodes icon + slider -->
                <Path Data="M3,8 A2,2 0 1,0 3,8.001 Z M8,3 A2,2 0 1,0 8,3.001 Z M13,8 A2,2 0 1,0 13,8.001 Z M3,8 L8,3 L13,8"
                      Fill="{StaticResource TextSecondaryBrush}"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1"
                      StrokeLineJoin="Round"
                      Stretch="Uniform"
                      Width="14" Height="14"
                      VerticalAlignment="Center"
                      Margin="4,0,4,0"
                      ToolTip="Vertex spacing (poligon/rajzolási sűrűség)"/>
                <Slider x:Name="DraftSpacingSlider"
                        Minimum="3" Maximum="40" Value="12"
                        Width="80"
                        VerticalAlignment="Center"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        ValueChanged="DraftSpacingSliderOnValueChanged"/>
                <TextBlock Text="{Binding ElementName=DraftSpacingSlider, Path=Value, StringFormat={}{0:0}px}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"
                           Width="28"/>

                <!-- AI Detection quick-run -->
                <Button x:Name="QuickDetBtn"
                        Style="{StaticResource IconButtonStyle}"
                        Width="34" Height="30"
                        ToolTip="AI Detektálás (gyors)"
                        Click="QuickDetectOnClick">
                    <Grid Width="18" Height="14">
                        <!-- Bounding box + AI spark -->
                        <Rectangle Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                   StrokeThickness="1.4" Width="14" Height="10"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <Path Data="M13,0 L15,4 L18,4 L15.5,6.5 L16.5,10 L13.5,8 L10.5,10 L11.5,6.5 L9,4 L12,4 Z"
                              Fill="{StaticResource AccentBlueBrush}"
                              Stretch="None"
                              Width="10" Height="10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"/>
                    </Grid>
                </Button>

                <!-- AI Segmentation quick-run -->
                <Button x:Name="QuickSegBtn"
                        Style="{StaticResource IconButtonStyle}"
                        Width="34" Height="30"
                        ToolTip="AI Szegmentálás (gyors)"
                        Click="QuickSegmentOnClick">
                    <Grid Width="18" Height="14">
                        <!-- Polygon + AI spark -->
                        <Path Data="M2,8 L5,2 L11,2 L14,8 L11,12 L5,12 Z"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.4"
                              Fill="Transparent"
                              Stretch="None"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"/>
                        <Path Data="M13,0 L15,4 L18,4 L15.5,6.5 L16.5,10 L13.5,8 L10.5,10 L11.5,6.5 L9,4 L12,4 Z"
                              Fill="{StaticResource AccentBlueBrush}"
                              Stretch="None"
                              Width="10" Height="10"
                              HorizontalAlignment="Right"
                              VerticalAlignment="Top"/>
                    </Grid>
                </Button>

                <!-- Vertical separator -->
                <Rectangle Width="1" Height="20" Fill="{StaticResource BorderBrush}" Margin="4,0"/>

                <!-- Brightness: sun icon -->
                <Path Data="M8,1 V3 M8,13 V15 M1,8 H3 M13,8 H15 M3,3 L4.5,4.5 M11.5,11.5 L13,13 M13,3 L11.5,4.5 M4.5,11.5 L3,13 M8,5 A3,3 0 1,0 8,11 A3,3 0 1,0 8,5 Z"
                      Fill="Transparent"
                      Stroke="{StaticResource TextSecondaryBrush}"
                      StrokeThickness="1.3"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Stretch="Uniform"
                      Width="14" Height="14"
                      VerticalAlignment="Center"
                      Margin="4,0,4,0"
                      ToolTip="Fényerő beállítás (csak nézethez, nem mentett)"/>
                <Slider x:Name="BrightnessSlider"
                        Minimum="-100" Maximum="100" Value="0"
                        Width="80"
                        VerticalAlignment="Center"
                        ValueChanged="BrightnessSliderOnValueChanged"/>
                <Button Style="{StaticResource IconButtonStyle}"
                        Width="24" Height="24"
                        ToolTip="Fényerő visszaállítása (0)"
                        Margin="2,0,0,0"
                        Click="ResetBrightnessOnClick">
                    <!-- Reset/circle arrow icon -->
                    <Path Data="M8,3 C5,3 3,5 3,8 C3,11 5,13 8,13 C11,13 13,11 13,8 M8,1 L10,4 L6,4 Z"
                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                          StrokeThickness="0.5"
                          StrokeLineJoin="Round"
                          Stretch="Uniform"
                          Width="11" Height="11"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- ══════ STATUS BAR ══════ -->
        <controls:AppStatusBar x:Name="StatusBar" DockPanel.Dock="Bottom"/>

        <!-- ══════ MAIN BODY ══════ -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="DatasetColumn" Width="220" MinWidth="160" MaxWidth="380"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition x:Name="InspectorColumn" Width="280" MinWidth="200" MaxWidth="420"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: Dataset Browser ── -->
            <Border Grid.Column="0"
                    x:Name="DatasetPanel"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                <controls:DatasetBrowserPanel x:Name="DatasetBrowser"/>
            </Border>

            <!-- Splitter left -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE"/>

            <!-- ── Canvas area ── -->
            <Grid Grid.Column="2" Background="{StaticResource CanvasBgBrush}">
                <imageControl:ImageViewport x:Name="Viewport"
                                            Style="{StaticResource DarkScrollViewerStyle}"
                                            MouseMove="ViewportOnMouseMove">
                    <Grid x:Name="ImageHost" Width="1" Height="1">
                        <Image x:Name="ImageView"
                               Stretch="Fill"
                               SnapsToDevicePixels="True"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <!-- Brightness overlay -->
                        <Rectangle x:Name="BrightnessOverlay"
                                   IsHitTestVisible="False"
                                   Opacity="0"/>
                        <tools:AnnotationCanvas x:Name="AnnotationCanvas"
                                                Document="{Binding Document}"
                                                CurrentLabel="{Binding ActiveLabelName}"
                                                CurrentColor="{Binding ActiveLabelColor}"
                                                ViewportZoom="{Binding ElementName=Viewport, Path=Zoom}"
                                                DraftPointSpacing="{Binding ElementName=DraftSpacingSlider, Path=Value}"/>
                    </Grid>
                </imageControl:ImageViewport>

                <!-- MiniMap – bottom-right corner -->
                <controls:MiniMapOverlay x:Name="MiniMap"
                                         Visibility="Collapsed"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Bottom"
                                         Margin="0,0,12,12"/>

                <!-- Empty state overlay -->
                <StackPanel x:Name="EmptyState"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <Path Data="M4,2 H10 L14,6 V15 H2 V2 Z M10,2 V6 H14 M6,10 H10 M6,12 H10 M6,8 H10"
                          Fill="Transparent"
                          Stroke="{StaticResource TextMutedBrush}"
                          StrokeThickness="1"
                          StrokeLineJoin="Round"
                          Stretch="Uniform"
                          Width="48" Height="48"
                          HorizontalAlignment="Center"
                          Margin="0,0,0,14"/>
                    <TextBlock Text="Open an image to start annotating"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="16"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Ctrl+O  ·  or drag and drop"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Splitter right -->
            <GridSplitter Grid.Column="3"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="Transparent"
                          Cursor="SizeWE"/>

            <!-- ── Right panel: Inspector ── -->
            <Border Grid.Column="4"
                    x:Name="InspectorPanel"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Label class panel -->
                        <RowDefinition Height="4"/>
                        <!-- Splitter -->
                        <RowDefinition Height="*"/>
                        <!-- Tab: Annotations / Image Info -->
                    </Grid.RowDefinitions>

                    <!-- Label Manager -->
                    <Border Grid.Row="0"
                            MaxHeight="280"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <controls:LabelClassPanel x:Name="LabelPanel"/>
                    </Border>

                    <!-- Label / bottom-panel splitter -->
                    <GridSplitter Grid.Row="1"
                                  Height="4"
                                  HorizontalAlignment="Stretch"
                                  Background="Transparent"
                                  Cursor="SizeNS"/>

                    <!-- Tab: Annotations | Image Info -->
                    <TabControl Grid.Row="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                        <TabItem Header="Annotációk">
                            <controls:AnnotationInspectorPanel x:Name="AnnotationInspector"/>
                        </TabItem>
                        <TabItem Header="Kép info">
                            <controls:ImageMetadataPanel x:Name="ImageMetadataPanel"/>
                        </TabItem>
                        <TabItem Header="Review">
                            <controls:ReviewPanel x:Name="ReviewPanel"/>
                        </TabItem>
                        <TabItem Header="AI feladatok">
                            <controls:AiJobsPanel x:Name="AiJobsPanel"/>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
