<Window x:Class="LabelForge.App.Dialogs.ImportProgressDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import" Width="420" Height="145" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" Background="{StaticResource PanelBgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <StackPanel Margin="22" VerticalAlignment="Center">
        <TextBlock x:Name="StatusText" Text="Dataset beolvasása..." Margin="0,0,0,12"/>
        <ProgressBar x:Name="Progress" Height="8" Minimum="0" Maximum="100"/>
    </StackPanel>
</Window>
