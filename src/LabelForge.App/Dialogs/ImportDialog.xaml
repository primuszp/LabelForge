<Window x:Class="LabelForge.App.Dialogs.ImportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Import Dataset"
        Width="560" MinWidth="480" Height="320" MinHeight="300"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top"
                   Text="Import Dataset"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button Content="Cancel"
                    Padding="14,6"
                    Margin="0,0,8,0"
                    Click="CancelOnClick"/>
            <Button x:Name="ImportButton"
                    Content="Import"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="14,6"
                    Click="ImportOnClick"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Store plugin"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>
            <ComboBox x:Name="PluginCombo"
                      DisplayMemberPath="DisplayName"
                      SelectedValuePath="Id"
                      MinHeight="30"
                      Margin="0,0,0,8"/>
            <TextBlock x:Name="PluginDescriptionText"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,16"/>

            <TextBlock Text="Dataset folder"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderBox"
                         MinWidth="0"
                         IsReadOnly="True"
                         Padding="7,5"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Grid.Column="1"
                        Content="Browse..."
                        Margin="8,0,0,0"
                        Padding="10,5"
                        FontSize="12"
                        Click="BrowseOnClick"/>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
