<Window x:Class="LabelForge.App.Dialogs.LabelMappingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI cimke-megfeleltetes" Width="560" Height="560" MinWidth="460" MinHeight="400"
        WindowStartupLocation="CenterOwner" Background="{StaticResource PanelBgBrush}">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <TextBlock Text="Modellprofil" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
            <ComboBox x:Name="ProfileBox" Margin="0,4,0,0" SelectionChanged="ProfileOnChanged"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Automatikus egyeztetes" Padding="12,6" Margin="0,0,8,0" Click="AutoMatchOnClick"/>
            <Button Content="Mentes" Style="{StaticResource AccentButtonStyle}" Padding="14,6" Click="SaveOnClick"/>
        </StackPanel>
        <DataGrid x:Name="MappingGrid" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Modell cimke" Binding="{Binding Source}" IsReadOnly="True" Width="*"/>
                <DataGridComboBoxColumn x:Name="TargetColumn" Header="Projekt cimke" SelectedItemBinding="{Binding Target, Mode=TwoWay}" Width="*"/>
                <DataGridCheckBoxColumn Header="Kihagyas" Binding="{Binding Skip, Mode=TwoWay}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
