<Window x:Class="LabelForge.App.Dialogs.ExportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Export Annotations"
        Width="440" Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PanelBgBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <DockPanel Margin="20">
        <!-- Title -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Export Annotations"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,16"/>

        <!-- Buttons -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Padding="14,6"
                    Margin="0,0,8,0"
                    Click="CancelOnClick"/>
            <Button x:Name="ExportButton"
                    Content="Export"
                    Style="{StaticResource AccentButtonStyle}"
                    Padding="14,6"
                    Click="ExportOnClick"/>
        </StackPanel>

        <!-- Content -->
        <StackPanel>
            <!-- Format selection -->
            <TextBlock Text="Format"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>

            <StackPanel Margin="0,0,0,16">
                <RadioButton x:Name="YoloRadio"
                             Content="YOLO  (.txt – normalized bbox / polygon)"
                             IsChecked="True"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="12"
                             Margin="0,0,0,6"/>
                <RadioButton x:Name="CocoRadio"
                             Content="COCO JSON  (full dataset, single file)"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="12"
                             Margin="0,0,0,6"/>
                <RadioButton x:Name="PascalRadio"
                             Content="Pascal VOC XML  (.xml per image)"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="12"/>
            </StackPanel>

            <!-- Scope -->
            <TextBlock Text="Scope"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>

            <StackPanel Margin="0,0,0,16">
                <RadioButton x:Name="CurrentImageRadio"
                             Content="Current image only"
                             IsChecked="True"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="12"
                             Margin="0,0,0,6"/>
                <RadioButton x:Name="EntireFolderRadio"
                             Content="Entire dataset folder"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontSize="12"/>
            </StackPanel>

            <!-- Output folder -->
            <TextBlock Text="Output folder"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,8"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="OutputFolderBox"
                         IsReadOnly="True"
                         Padding="7,5"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"/>
                <Button Grid.Column="1"
                        Content="Browse…"
                        Margin="8,0,0,0"
                        Padding="10,5"
                        FontSize="12"
                        Click="BrowseOutputOnClick"/>
            </Grid>
        </StackPanel>
    </DockPanel>
</Window>
